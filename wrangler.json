{
  "name": "mybooks",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  "workers_dev": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "upload_source_maps": true,
  "vars": {
    "APP_NAME": "EMPRO MyBooks",
    "APP_DOMAIN": "billing.empro.biz",
    "SENDGRID_FROM": "Billing <brian@empro.biz>",
    "AXIOM_DATASET": "sparkletext",
    "AXIOM_REGION": "us",
    "AXIOM_APP_ID": "mybooks",
    "AXIOM_ENV": "prod"
  },
  "browser": {
    "binding": "MYBROWSER"
  },
  "assets": {
    "directory": "admin/dist",
    "binding": "ASSETS",
    "html_handling": "none",
    "run_worker_first": ["/api/*", "/webhook/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mybooks",
      "database_id": "b1c37a41-1c38-4fc3-939e-e016c285abc4"
    }
  ],
  "triggers": {
    "crons": ["0 */6 * * *"]
  }
}
